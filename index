    <div class="pros-vs">vs</div>

    <div class="pros-col">
      <div class="pros-header bio">
        <div class="pros-name">🌿 Biologische klep</div>
        <div class="pros-sub">Gepericardiseerd rundvleesweefsel of varkenslongader</div>
